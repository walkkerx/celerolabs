// PRODUCTION SCHEMA — PostgreSQL (Neon/Supabase)
// This file is used when building for production (Netlify).
// The build script copies it over schema.prisma before running prisma generate.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  lastName  String?
  consent   Boolean  @default(false)
  source    String   @default("capital_page")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvestmentInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  amount    Float
  tier      String
  accredited Boolean @default(false)
  consent   Boolean  @default(false)
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id        String   @id @default(cuid())
  type      String
  firstName String
  lastName  String
  email     String
  referral  String?
  linkedinUrl    String?
  companyName    String?
  companyWebsite String?
  location       String?
  role           String?
  pitchDeckUrl   String?
  motivation     String?
  orgName    String?
  orgWebsite String?
  partnerRole String?
  interest   String?
  description String?
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobApplication {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  linkedinUrl String?
  portfolioUrl String?
  role      String
  location  String?
  availability String?
  motivation String?
  referral  String?
  resumeUrl String?
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProgramApplication {
  id        String   @id @default(cuid())
  programSlug String
  firstName String
  lastName  String
  email     String
  phone     String?
  linkedinUrl String?
  location  String?
  currentRole String?
  companyName String?
  motivation String?
  referral  String?
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Town Square / Forum Models ───

model ForumUser {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  bio         String?
  role        String
  location    String?
  communities String   @default("")
  avatarColor String   @default("#6b7280")
  avatarUrl   String?
  company     String?
  title       String?
  lastActiveAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts     ForumPost[]
  comments  ForumComment[]
  votes     ForumVote[]
  hearts    ForumHeart[]

  @@index([lastActiveAt(sort: Desc)])
  @@index([role])
}

model ForumPost {
  id         String   @id @default(cuid())
  authorId   String
  community  String
  title      String
  content    String?
  upvotes    Int      @default(0)
  hearts     Int      @default(0)
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author    ForumUser     @relation(fields: [authorId], references: [id])
  comments  ForumComment[]
  votes     ForumVote[]
  heartUsers ForumHeart[]

  @@index([community, createdAt(sort: Desc)])
  @@index([community, upvotes(sort: Desc)])
  @@index([upvotes(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([authorId])
}

model ForumComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     ForumPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   ForumUser     @relation(fields: [authorId], references: [id])
  parent   ForumComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ForumComment[] @relation("CommentReplies")
  votes    ForumVote[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model ForumVote {
  id         String  @id @default(cuid())
  userId     String
  postId     String?
  commentId  String?
  direction  String

  user       ForumUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       ForumPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

model ForumHeart {
  id     String @id @default(cuid())
  userId String
  postId String

  user   ForumUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}
